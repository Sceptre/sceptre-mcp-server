{
  "name": "Lint on Save",
  "version": "1.0.0",
  "description": "Run pre-commit hooks on saved Python files",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*.py",
      "*.yaml",
      "*.yml",
      "*.json"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "pre-commit run --files ${file}"
  }
}
